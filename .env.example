# Optional: collect only this quote asset contracts
QUOTE_ASSET=USDT

# Optional: explicit symbols list, comma-separated (higher priority than SYMBOL_LIMIT)
# TARGET_SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT
TARGET_SYMBOLS=

# Number of contracts to track when no explicit symbol is provided
SYMBOL_LIMIT=80

# Exchanges to aggregate OI from (ccxt exchange ids)
AGG_EXCHANGES=binanceusdm,bybit,okx,bitget,gateio,kucoinfutures,mexc,bingx

# Exchange request timeout (ms)
EXCHANGE_TIMEOUT_MS=20000

# If batch API misses too many symbols, skip single-symbol fallback
FALLBACK_SINGLE_FETCH_THRESHOLD=120

# Keep N hours of data
RETENTION_HOURS=48

# Hard cap points per symbol
MAX_POINTS_PER_SYMBOL=3000

# Vercel cron auth token (recommended in production)
CRON_SECRET=

# Optional token to protect /api/collect manual trigger
COLLECT_TOKEN=

# Optional: enable Upstash Redis storage for Vercel persistence
KV_REST_API_URL=
KV_REST_API_TOKEN=
